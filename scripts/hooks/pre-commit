#!/bin/bash
#
# Pre-commit hook: Enforce ticket tracking for code changes
#
# Blocks commits when code files are changed without an active ticket session.
# Sessions are stored in SQLite (.ticket/state.db), managed by `ticket` CLI.
# To start a session: ticket start <ticket-id>
#

set -e

# Resolve main repo root — works in both main checkout and worktrees.
GIT_COMMON="$(git rev-parse --git-common-dir)"
if [ "$GIT_COMMON" = ".git" ]; then
    REPO_ROOT="$(git rev-parse --show-toplevel)"
else
    REPO_ROOT="$(cd "$GIT_COMMON/.." && pwd)"
fi

# Check if any code files are staged
CODE_STAGED=false
for file in $(git diff --cached --name-only --diff-filter=ACMR); do
    case "$file" in
        src/*|tests/*|crates/*|examples/*|*.rs)
            CODE_STAGED=true
            break
            ;;
    esac
done

# Docs-only commits bypass session enforcement
if [ "$CODE_STAGED" = false ]; then
    exit 0
fi

# Code files are staged — enforce ticket session via reconcile
if ! ticket reconcile --json --strict --repo-root "$REPO_ROOT" >/dev/null 2>&1; then
    echo "ERROR: ticket reconcile failed."
    echo ""
    ticket reconcile --repo-root "$REPO_ROOT" || true
    echo ""
    echo "If no active session, run: ticket start <ticket-id>"
    echo "Fix the reported issues, then retry your commit."
    exit 1
fi

exit 0
