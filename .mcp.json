{
  "mcpServers": {
    "aster-orch-dev": {
      "command": "cargo",
      "args": [
        "run",
        "--manifest-path", "/Users/ottogiron/workspace/github.com/ottogiron/aster-orch/Cargo.toml",
        "--bin", "aster_orch",
        "--",
        "mcp-server",
        "--config", "/Users/ottogiron/workspace/github.com/ottogiron/aster-orch/.aster-orch/config.yaml"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    }
  }
}
